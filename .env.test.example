# Пример переменных окружения для тестовой среды.
# НЕ используйте production ключи — тесты не обращаются к внешним сервисам.
# Инфраструктура:
#   docker compose -f docker-compose.test.yml up -d --wait
#
# Routing к тестовой БД/Redis/MinIO происходит автоматически в tests/conftest.py
# (os.environ override до импорта api.settings). Не требуется копировать в .env
# (это изолирует от production .env). AI_API_KEY= => FakeAIClient, без внешних вызовов.

# --- Postgres (изолированный инстанс) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_DB=furniture_ai_test
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_only_password

# --- Redis (изолированный инстанс) ---
REDIS_URL=redis://:test_redis_password@127.0.0.1:6381/0
GUEST_UPLOAD_SECRET=test-guest-upload-secret-32bytes-minimum-2026
TRUSTED_PROXY_CIDRS=127.0.0.1/32,172.16.0.0/12

# --- MinIO / S3 (изолированный инстанс) ---
S3_ENDPOINT_URL=http://127.0.0.1:9004
S3_REGION=us-east-1
S3_ACCESS_KEY=test_minio_user
S3_SECRET_KEY=test_minio_secret_2026
S3_BUCKET=test-artifacts
S3_PRESIGNED_TTL_SECONDS=900

# --- AI (пустой = mock-режим, никаких HTTP-вызовов) ---
AI_BASE_URL=
AI_API_KEY=
AI_CHAT_MODEL=fake-model
AI_VISION_MODEL=fake-vision-model
AI_EMBEDDING_MODEL=fake-embedding-model

# --- JWT (тестовый секрет, НЕ для production) ---
JWT_SECRET=test-only-jwt-secret-not-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=1

# --- Email (пустой = mock-режим) ---
RUSENDER_API_KEY=
RUSENDER_SENDING_KEY_ID=
EMAIL_FROM=test@example.com
FRONTEND_URL=http://localhost:3000
